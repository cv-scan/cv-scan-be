# ─── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_PREFIX=/api/v1
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yWbVsmGpVSuXb0LExPyZpyEY@localhost:5431/cv_scan_db?&sslmode=disable&schema=partner
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Redis (batch queue only) ─────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6378
REDIS_PASSWORD=
REDIS_DB=0
# REDIS_TLS=true   ← bật khi dùng Upstash (production)

# ─── Authentication ───────────────────────────────────────────
JWT_SECRET=replace-with-min-32-char-random-string-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# ─── File Storage ─────────────────────────────────────────────
STORAGE_PROVIDER=local
MAX_FILE_SIZE_MB=10

# Local storage
LOCAL_UPLOAD_DIR=./uploads

# AWS S3 (chỉ cần nếu STORAGE_PROVIDER=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=cv-scan-uploads
S3_PRESIGNED_URL_EXPIRES=3600

# Cloudinary (chỉ cần nếu STORAGE_PROVIDER=cloudinary)
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=dxl7tocmq
CLOUDINARY_API_KEY=914184643698599
CLOUDINARY_API_SECRET=JKaUsK3Buv2vvcN8dZ97iCWc_Y8

# ─── Queue Configuration ──────────────────────────────────────
QUEUE_EVALUATION_CONCURRENCY=20
QUEUE_BATCH_CONCURRENCY=5
QUEUE_JOB_ATTEMPTS=3

# ─── CORS ─────────────────────────────────────────────────────
# Nhiều origins: dùng dấu phẩy ngăn cách (không có khoảng trắng hoặc có đều được)
CORS_ORIGIN=http://localhost:3001,http://localhost:3003
CORS_CREDENTIALS=true

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Bull Board Dashboard ─────────────────────────────────────
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=change-this-password
