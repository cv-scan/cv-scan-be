# ─── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_PREFIX=/api/v1
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://cv_user:cv_password@localhost:5432/cv_scan_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Redis (batch queue only) ─────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Authentication ───────────────────────────────────────────
JWT_SECRET=replace-with-min-32-char-random-string-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# ─── File Storage ─────────────────────────────────────────────
STORAGE_PROVIDER=local
MAX_FILE_SIZE_MB=10

# Local storage
LOCAL_UPLOAD_DIR=./uploads

# AWS S3 (chỉ cần nếu STORAGE_PROVIDER=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=cv-scan-uploads
S3_PRESIGNED_URL_EXPIRES=3600

# ─── Queue Configuration ──────────────────────────────────────
QUEUE_EVALUATION_CONCURRENCY=20
QUEUE_BATCH_CONCURRENCY=5
QUEUE_JOB_ATTEMPTS=3

# ─── CORS ─────────────────────────────────────────────────────
# Nhiều origins: dùng dấu phẩy ngăn cách (không có khoảng trắng hoặc có đều được)
CORS_ORIGIN=http://localhost:3001,http://localhost:3003
CORS_CREDENTIALS=true

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Bull Board Dashboard ─────────────────────────────────────
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=change-this-password
